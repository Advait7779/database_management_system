{
    admin off
    auto_https off
}

:{$PORT:80} {
    encode gzip

    log {
        output stdout
    }

    # Proxy all /api/* requests to the backend service
    handle /api/* {
        reverse_proxy {$BACKEND_URL:db-backend:3001} {
            header_up Host {host}
            header_up X-Real-IP {remote_host}
        }
    }

    # Serve static React build with SPA fallback
    handle {
        root * /app/dist
        try_files {path} /index.html
        file_server
    }
}
